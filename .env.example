# =============================================================================
# SUNFLIX — copy this file to ".env" in the project root and fill in values.
# Vite only exposes variables that start with VITE_. Restart "npm run dev" after edits.
# =============================================================================

# --- TMDB (movie posters & metadata) -----------------------------------------
# https://www.themoviedb.org/settings/api — create a key, paste below (optional:
# a dev fallback exists in code, but you should use your own key in production).
VITE_TMDB_API_KEY=

# --- Supabase (auth + database + realtime) ----------------------------------
# 1) Create a project: https://supabase.com/dashboard → New project
# 2) Wait for DB to finish provisioning.
# 3) Project Settings → API:
#    - "Project URL"        → VITE_SUPABASE_URL
#    - "anon public" key    → VITE_SUPABASE_ANON_KEY  (NOT the service_role key)
# 4) SQL Editor → paste and run the script in: supabase/schema.sql
#    This creates tables profiles, watchlist, watch_parties + RLS policies.
# 5) Authentication → Providers: enable Email. URL Configuration: add your site URL for prod.
# 6) (Optional) Database → Replication: enable realtime for "watchlist" if you want live list updates.
# 7) Save this file as .env and run: npm run dev

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Demo mode ---------------------------------------------------------------
# Set to "true" to allow demo@sunflix.app / demo even when Supabase is configured.
# In development, demo login also works without Supabase unless VITE_AUTH_DEMO=false.
VITE_AUTH_DEMO=false
